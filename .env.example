# =============================================================================
# WhatsApp Catalog Ordering Bot - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Supabase (PostgreSQL Database) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# --- Meta WhatsApp Cloud API ---
META_APP_SECRET=your_meta_app_secret
WHATSAPP_VERIFY_TOKEN=your_custom_webhook_verify_token
WHATSAPP_API_VERSION=v22.0

# --- Google Sheets (Catalog Sync) ---
# Path to your Google service account JSON file
# OR paste the entire JSON content as a single line
GOOGLE_SHEETS_CREDENTIALS=path/to/service-account.json

# --- Razorpay Payment Gateway ---
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_your_key_id

# --- CORS (Frontend origins) ---
CORS_ORIGINS=http://localhost:3000

# --- Application ---
LOG_LEVEL=INFO
