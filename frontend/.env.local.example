# Local dev
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production: Vercel rewrites proxy /api/* to Render, so NEXT_PUBLIC_API_URL is
# not needed. Leave it unset in Vercel env vars — backend URL stays hidden.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Meta/Facebook App ID for WhatsApp Embedded Signup
NEXT_PUBLIC_FACEBOOK_APP_ID=
